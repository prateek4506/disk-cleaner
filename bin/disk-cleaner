#!/usr/bin/env python3
# Thin entrypoint so `disk-cleaner` works as a CLI (Homebrew/curl install).
# Delegates to the bundled implementation.
import os
import runpy
import sys

HERE = os.path.dirname(os.path.realpath(__file__))
IMPL = os.path.join(HERE, "..", "DiskCleaner.app", "Contents", "Resources", "disk_cleaner.py")
sys.argv[0] = "disk-cleaner"
runpy.run_path(os.path.abspath(IMPL), run_name="__main__")
